  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Unity.TextMeshPro::TMPro.TextMeshProUGUI
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\n\n1. M\u1EE4C TI\xCAU CHI\u1EBEN D\u1ECACH:\n\nT\xECm t\u1EDBi c\xE1n
    b\u1ED9 nh\u1EADn nhi\u1EC7m v\u1EE5 v\xE0 kh\u1EDFi \u0111\u1ED9ng xe th\u1EF1c
    hi\u1EC7n nhi\u1EC7m v\u1EE5.\n\nV\u1EC1 \u0111\xEDch \u0111\xFAng gi\u1EDD:
    Quan s\xE1t \u0111\u1ED3ng h\u1ED3 b\u1EA5m gi\u1EDD tr\xEAn m\xE0n h\xECnh.
    \u0110\u1ED3ng ch\xED ph\u1EA3i c\xE1n \u0111\xEDch tr\u01B0\u1EDBc khi th\u1EDDi
    gian c\u1EA1n ki\u1EC7t.\n\nB\xE1o c\xE1o c\u1EA5p tr\xEAn: Sau khi l\xE1i xe
    qua v\u1EA1ch \u0111\xEDch th\xE0nh c\xF4ng, \u0111\u1ED3ng ch\xED h\xE3y ti\u1EBFn
    l\u1EA1i g\u1EA7n Ch\u1EC9 Huy (NPC) v\xE0 \u1EA5n [F] \u0111\u1EC3 b\xE1o c\xE1o
    ho\xE0n th\xE0nh nhi\u1EC7m v\u1EE5.\n\n2. THAO T\xC1C \u0110I\u1EC0U KHI\u1EC2N:\n\n[W]
    [A] [S] [D] : \u0111\u1EC3 di chuy\u1EC3n xe v\xE0 nh\xE2n v\u1EADt\n\n[Shift]
    [Chu\u1ED9t ph\u1EA3i]: t\u0103ng t\u1ED1c \u0111\u1ED9 \n\n[Space]: Phanh g\u1EA5p
    / K\xE9o phanh tay.\n\n[Chu\u1ED9t]: Xoay g\xF3c nh\xECn camera \u0111\u1EC3
    quan s\xE1t \u0111\u01B0\u1EDDng \u0111i.\n\n[F]: T\u01B0\u01A1ng t\xE1c (\u0110\u1ECDc
    t\xE0i li\u1EC7u, n\xF3i chuy\u1EC7n v\u1EDBi NPC)."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 798542af62b34e2428de560d247831ae, type: 2}
