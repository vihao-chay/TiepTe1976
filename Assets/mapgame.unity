  m_Script: {fileID: 11500000, guid: 4727d7673f17bae4982b37b648f364ab, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCInteract
  promptUI: {fileID: 1476669050}
  dialogueManager: {fileID: 2051986762}
  npcName: "Tr\u1EA1m Tr\u01B0\u1EDFng"
  dialogueCamera: {fileID: 1896589146}
  sentences:
  - "Ch\xE0o \u0111\u1ED3ng ch\xED. May qu\xE1, t\xF4i \u0111ang c\u1EA7n g\u1EB7p
    c\u1EADu."
  - "Tr\u1EA1m v\u1EEBa nh\u1EADn \u0111\u01B0\u1EE3c li\xEAn l\u1EA1c kh\u1EA9n."
  - "M\u1ED9t t\u1ED5 c\xF4ng t\xE1c \u0111ang d\u1EABn ng\u01B0\u1EDDi t\u1ECB n\u1EA1n
    v\u1EC1 khu an to\xE0n nh\u01B0ng b\u1ECB k\u1EB9t l\u1EA1i v\xEC c\xE2y \u0111\u1ED5
    ch\u1EAFn \u0111\u01B0\u1EDDng."
  - "L\u01B0\u01A1ng th\u1EF1c c\u1EE7a h\u1ECD s\u1EAFp c\u1EA1n."
  - "H\u1ECD \u0111ang \u1EDF ph\xEDa t\xE2y b\u1EAFc khu r\u1EEBng n\xE0y."
  - "\u0110\u1ED3ng ch\xED h\xE3y ch\u1EDF l\u01B0\u01A1ng th\u1EF1c v\xE0 v\u1EADt
    t\u01B0 \u0111\u1EBFn ti\u1EBFp t\u1EBF cho h\u1ECD."
  - "C\u1EA9n th\u1EADn tr\xEAn \u0111\u01B0\u1EDDng \u0111i."
