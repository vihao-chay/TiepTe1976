  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCInteract
  promptUI: {fileID: 477028023}
  dialogueManager: {fileID: 2051986762}
  npcName: "Trung \u0110\u1ED9i Tr\u01B0\u1EDFng Ho\xE0ng"
  dialogueCamera: {fileID: 774564361}
  sentences:
  - sentenceText: "\u0110\u1ED3ng ch\xED \u0111\u1EBFn r\u1ED3i!"
    voiceClip: {fileID: 8300000, guid: 20c399e366bab9c4b9af359151d2c2f4, type: 3}
  - sentenceText: "Ch\xFAng t\xF4i \u0111ang ch\u1EDD chuy\u1EBFn h\xE0ng n\xE0y."
    voiceClip: {fileID: 8300000, guid: 40ec730cdcd578948a2a546e3bfdf547, type: 3}
  - sentenceText: "Nhanh ch\xF3ng b\xE0n giao h\xE0ng!"
    voiceClip: {fileID: 8300000, guid: bb0ad4cc9a9a97e4b8fc1dd054fb3529, type: 3}
  reportSentences:
  - sentenceText: "H\xE0ng \u0111\xE3 \u0111\u01B0\u1EE3c ti\u1EBFp nh\u1EADn \u0111\u1EA7y
      \u0111\u1EE7."
    voiceClip: {fileID: 0}
  - sentenceText: "C\u1EA3m \u01A1n \u0111\u1ED3ng ch\xED!"
    voiceClip: {fileID: 0}
  - sentenceText: "\u0110\u1ED3ng ch\xED c\xF3 th\u1EC3 quay v\u1EC1 b\xE1o c\xE1o."
    voiceClip: {fileID: 0}
  day1Sentences: []
  day2Sentences: []
  day3Sentences: []
  day1ReportSentences: []
  day2ReportSentences: []
  day3ReportSentences: []
  actionType: 2
  questArrow: {fileID: 1190181045}
  isFinished: 0
  finalOutroMessage: "T\u1EA1m bi\u1EC7t chi\u1EBFn s\u0129, h\u1EB9n g\u1EB7p l\u1EA1i!"
